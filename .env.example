BOT_TOKEN=your_telegram_bot_token
# Локально без Docker: redis://localhost:6379/0
# Для Docker/production: redis://:${REDIS_PASSWORD}@redis:6379/0
REDIS_URL=redis://localhost:6379/0
LOG_LEVEL=INFO
OPENAI_API_KEY=your_openai_api_key
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LABELING_DB_PATH=data/images/cards.db
PAIR_SIMILARITY_THRESHOLD=0.55
PAIR_HISTORY_SIZE=50
PAIR_SELECTION_MODE=pairwise_topk
PAIR_SEED_RETRY_LIMIT=3
PAIR_LOGPROB_THRESHOLD=-2.3
METRICS_ENABLED=false
METRICS_HOST=0.0.0.0
METRICS_PORT=8001

# 🔒 Безопасность (для продакшен-развертывания)
# Сгенерируйте стойкие пароли: openssl rand -base64 32 | tr -d '/+=' | cut -c1-32
REDIS_PASSWORD=changeme_generate_strong_password
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_generate_strong_password
GRAFANA_ROOT_URL=http://localhost:3000
